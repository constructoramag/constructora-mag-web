# Variables de entorno — Constructora MAG
# Crea un archivo .env en la raíz del proyecto y rellena los valores.
# Consíguelos en https://www.sanity.io/manage → tu proyecto → Settings → API

# ── Sanity CMS ────────────────────────────────────────────────────────────────

# ID de tu proyecto de Sanity (requerido para activar el CMS)
VITE_SANITY_PROJECT_ID=TU_PROJECT_ID_AQUI

# Dataset (normalmente "production")
VITE_SANITY_DATASET=production

# ── Opcional: token para datos en tiempo real (sin caché CDN) ─────────────────
# Solo necesario si quieres ver cambios del Studio al instante sin esperar al CDN.
# Créalo en sanity.io/manage → tu proyecto → API → Tokens
# VITE_SANITY_TOKEN=TU_TOKEN_AQUI
